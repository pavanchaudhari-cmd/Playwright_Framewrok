    "gen-context:ts": "tsx scripts/generate-context.ts",
    "gen-types": "tsx scripts/generate-types.ts",
    "report:allure:generate": "allure generate --output allure-report allure-results",
    "report:allure:open": "npx allure open allure-report",
    "report:allure": "npm run report:allure:generate && npm run report:allure:open"
  },
